function renderizarGraficoVendasPizza(){
  var canvas = document.getElementById("graficoVendasPizza");
  if(!canvas) return;
  if(typeof vendas === "undefined" || !Array.isArray(vendas)) return;

  var grupos = {
    "Aguardando pagamento": 0,
    "Faturado": 0,
    "Entregue": 0,
    "Pedido cancelado": 0
  };

  vendas.forEach(function(v){
    var status = v.statusVenda || "Aguardando pagamento";
    if(!grupos.hasOwnProperty(status)) grupos[status] = 0;
    grupos[status]++;
  });

  var labels = Object.keys(grupos);
  var valores = labels.map(function(label){ return grupos[label]; });
  var total = valores.reduce(function(a,b){ return a+b; }, 0);

  var ctx = canvas.getContext("2d");
  var w = canvas.clientWidth || 900;
  var h = canvas.clientHeight || 360;
  canvas.width = w;
  canvas.height = h;

  ctx.clearRect(0,0,w,h);

  if(total === 0){
    ctx.fillStyle = "#5681b5";
    ctx.font = "16px Arial";
    ctx.textAlign = "left";
    ctx.fillText("Nenhuma venda registrada para gerar o gráfico.", 20, 40);
    return;
  }

  var cx = Math.min(w * 0.38, 310);
  var cy = h / 2;
  var raio = Math.min(120, h / 2 - 35);
  var cores = ["#f59e0b", "#3b82f6", "#10b981", "#ef4444", "#8b5cf6", "#64748b"];
  var angulo = -Math.PI / 2;

  labels.forEach(function(label, i){
    var valor = valores[i];
    if(valor <= 0) return;

    var fatia = (valor / total) * Math.PI * 2;

    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.arc(cx, cy, raio, angulo, angulo + fatia);
    ctx.closePath();
    ctx.fillStyle = cores[i % cores.length];
    ctx.fill();

    angulo += fatia;
  });

  // centro branco estilo donut
  ctx.beginPath();
  ctx.arc(cx, cy, raio * 0.45, 0, Math.PI * 2);
  ctx.fillStyle = "#ffffff";
  ctx.fill();

  ctx.fillStyle = "#102a43";
  ctx.textAlign = "center";
  ctx.font = "bold 22px Arial";
  ctx.fillText(total, cx, cy + 5);
  ctx.font = "12px Arial";
  ctx.fillText("vendas", cx, cy + 25);

  // legenda
  var lx = Math.min(w - 310, cx + raio + 80);
  if(lx < cx + raio + 35) lx = cx + raio + 35;
  var ly = Math.max(50, cy - 85);

  ctx.textAlign = "left";
  labels.forEach(function(label, i){
    var valor = valores[i];
    var pct = total > 0 ? ((valor / total) * 100).toFixed(1).replace(".", ",") : "0,0";

    ctx.fillStyle = cores[i % cores.length];
    ctx.fillRect(lx, ly + i * 42, 18, 18);

    ctx.fillStyle = "#102a43";
    ctx.font = "14px Arial";
    ctx.fillText(label + " — " + valor + " (" + pct + "%)", lx + 28, ly + 14 + i * 42);
  });
}

