function calcNumero(id){
  var el = document.getElementById(id);
  if(!el) return 0;

  var valor = String(el.value || "0").trim();
  valor = valor.replace(/\s/g, "").replace("R$", "");

  // Aceita padrão brasileiro: 1.234,56
  if(valor.indexOf(",") >= 0){
    valor = valor.replace(/\./g, "").replace(",", ".");
  }

  return Number(valor) || 0;
}

function calcMoeda(valor){
  return Number(valor || 0).toLocaleString("pt-BR", {style:"currency", currency:"BRL"});
}

function calcularMargem(){
  var custo = calcNumero("calcCusto");
  var preco = calcNumero("calcPreco");
  var comissaoPercentual = calcNumero("calcComissao");
  var frete = calcNumero("calcFrete");
  var devolucaoPercentual = calcNumero("calcDevolucao");
  var variavelPercentual = calcNumero("calcVariavel");

  var valorComissao = preco * (comissaoPercentual / 100);
  var valorDevolucao = preco * (devolucaoPercentual / 100);
  var valorVariavel = preco * (variavelPercentual / 100);

  // Igual à lógica do print:
  // Valor líquido a receber NÃO desconta custo do produto, devolução ou outras taxas.
  var valorLiquidoReceber = preco - valorComissao - frete;

  // MC R$ desconta custo do produto + devolução (%) + custos variáveis (%).
  var lucroReal = valorLiquidoReceber - custo - valorDevolucao - valorVariavel;

  // MC % é calculado sobre o preço anunciado.
  var margemReal = preco > 0 ? (lucroReal / preco) * 100 : 0;

  if(document.getElementById("resComissao")) document.getElementById("resComissao").textContent = calcMoeda(valorComissao);
  if(document.getElementById("resFrete")) document.getElementById("resFrete").textContent = calcMoeda(frete);
  if(document.getElementById("resDevolucao")) document.getElementById("resDevolucao").textContent = calcMoeda(valorDevolucao);
  if(document.getElementById("resVariavel")) document.getElementById("resVariavel").textContent = calcMoeda(valorVariavel);
  if(document.getElementById("resValorLiquido")) document.getElementById("resValorLiquido").textContent = calcMoeda(valorLiquidoReceber);
  if(document.getElementById("resLucroReal")) document.getElementById("resLucroReal").textContent = calcMoeda(lucroReal);
  if(document.getElementById("resMargem")) document.getElementById("resMargem").textContent = margemReal.toFixed(2).replace(".", ",") + "%";
}

function limparCalculadora(){
  ["calcCusto","calcPreco","calcComissao","calcFrete","calcDevolucao","calcVariavel"].forEach(function(id){
    var el = document.getElementById(id);
    if(el) el.value = "";
  });

  if(document.getElementById("resComissao")) document.getElementById("resComissao").textContent = "R$ 0,00";
  if(document.getElementById("resFrete")) document.getElementById("resFrete").textContent = "R$ 0,00";
  if(document.getElementById("resDevolucao")) document.getElementById("resDevolucao").textContent = "R$ 0,00";
