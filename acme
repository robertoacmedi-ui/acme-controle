function exportarRelatorioCSV(){
  try{
    var linhas = [];
    linhas.push([
      "Data da venda",
      "SKU",
      "Produto",
      "Número do pedido",
      "Status da venda",
      "Data de criação"
    ]);

    if(typeof vendas === "undefined" || !Array.isArray(vendas)){
      alert("Nenhuma venda encontrada para exportar.");
      return;
    }

    vendas.forEach(function(v){
      var dataVenda = "";
      if(typeof dataVendaInicial === "function"){
        dataVenda = formatarData(dataVendaInicial(v));
      }else{
        dataVenda = v.dataVenda || "";
      }

      linhas.push([
        dataVenda,
        v.sku || "",
        v.produto || "",
        v.numeroPedido || "",
        v.statusVenda || "",
        v.criadoEm || ""
