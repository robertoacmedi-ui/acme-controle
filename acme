function formatarDataInput(data){
  if(!data) return "";
  if(String(data).includes("-")) return data;
  var partes = String(data).split("/");
  if(partes.length === 3){
    return partes[2] + "-" + partes[1].padStart(2,"0") + "-" + partes[0].padStart(2,"0");
  }
  return "";
}

function dataVendaInicial(venda){
  if(venda.dataVenda) return formatarDataInput(venda.dataVenda);

  if(venda.criadoEm){
    var partes = String(venda.criadoEm).split(" ")[0].split("/");
    if(partes.length === 3){
      return partes[2] + "-" + partes[1].padStart(2,"0") + "-" + partes[0].padStart(2,"0");
    }
  }

  return hoje();
}

