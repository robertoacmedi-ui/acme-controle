<script>
(function(){
function escapeRankingSkuUnico(t){
  if(typeof escapeHtml === "function") return escapeHtml(t);
  return String(t || "").replace(/[&<>"']/g, m => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[m]));
}

function quantidadeVendaSkuUnico(v){
  const qtd = Number(v.quantidadeItens || v.quantidade || v.qtd || 1);
  return qtd > 0 ? qtd : 1;
}

window.renderizarRankingProdutosVendidos = function(){
  const tbody = document.getElementById("rankingProdutosVendidos");
  if(!tbody) return;

  if(typeof vendas === "undefined" || !Array.isArray(vendas) || !vendas.length){
    tbody.innerHTML = '<tr><td colspan="4" class="empty">Nenhuma venda registrada.</td></tr>';
    return;
  }

  const grupos = {};

  vendas.forEach(v => {
    const sku = String(v.sku || "SEM SKU").trim().toUpperCase() || "SEM SKU";

    if(!grupos[sku]){
      grupos[sku] = {
        sku: sku,
        produto: String(v.produto || v.nomeProduto || sku || "Produto sem nome").trim(),
        quantidade: 0
      };
    }

    grupos[sku].quantidade += quantidadeVendaSkuUnico(v);

    // Mantém o primeiro nome de produto mais completo encontrado
    const nomeAtual = String(grupos[sku].produto || "").trim();
    const novoNome = String(v.produto || v.nomeProduto || "").trim();
    if(novoNome && (nomeAtual === sku || novoNome.length > nomeAtual.length)){
      grupos[sku].produto = novoNome;
    }
  });

  const ranking = Object.values(grupos)
    .sort((a,b) => b.quantidade - a.quantidade || a.sku.localeCompare(b.sku))
    .slice(0,15);

  tbody.innerHTML = "";

  ranking.forEach((item, index) => {
    tbody.innerHTML += `<tr>
      <td><span class="badge">${index + 1}º</span></td>
      <td class="sku-title">${escapeRankingSkuUnico(item.sku)}</td>
      <td>${escapeRankingSkuUnico(item.produto || item.sku)}</td>
      <td><strong>${item.quantidade}</strong></td>
    </tr>`;
  });
};

})();
</script>


<script>
(function(){

function acmeDataOrdenacao(v){
  const d = v.dataVenda || v.data || "";
  if(!d) return 0;
  const date = new Date(d + "T12:00:00");
  return isNaN(date.getTime()) ? 0 : date.getTime();
}

function ordenarListaVendas(lista){
  const modo = document.getElementById("filtroOrdenacaoVendas")?.value || "recentes";

  return [...lista].sort((a,b)=>{
    const da = acmeDataOrdenacao(a);
    const db = acmeDataOrdenacao(b);

    if(modo === "antigas"){
      return da - db;
    }

    return db - da;
  });
}

// intercepta o relatório automático
const relatorioOriginalOrdenacao = window.obterVendasRelatorioAvancado;

if(typeof relatorioOriginalOrdenacao === "function"){
  window.obterVendasRelatorioAvancado = function(){
    const lista = relatorioOriginalOrdenacao();
    return ordenarListaVendas(lista);
  };
}

// ordenação da aba vendas principal
function ordenarTabelaVendasPrincipal(){
  if(typeof vendas === "undefined" || !Array.isArray(vendas)) return;

  const modo = document.getElementById("filtroOrdenacaoVendas")?.value || "recentes";

  vendas.sort((a,b)=>{
    const da = acmeDataOrdenacao(a);
    const db = acmeDataOrdenacao(b);

    if(modo === "antigas"){
      return da - db;
    }

    return db - da;
  });
}

const atualizarTudoOrdenacao = window.atualizarTudo;

window.atualizarTudo = function(){
  ordenarTabelaVendasPrincipal();

  if(typeof atualizarTudoOrdenacao === "function"){
    atualizarTudoOrdenacao();
  }
};

window.addEventListener("load", function(){
  setTimeout(()=>{
    try{
      ordenarTabelaVendasPrincipal();
      if(typeof renderizarRelatorioAvancado === "function"){
        renderizarRelatorioAvancado();
      }
    }catch(e){}
  }, 300);
});

})();
</script>


<script>
(function(){
function relEsc(t){
  if(typeof escapeHtml === "function") return escapeHtml(t);
  return String(t||"").replace(/[&<>"']/g,m=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[m]));
}
function relNum(v){
  if(v===null||v===undefined||v==="") return 0;
  let s=String(v).trim().replace(/\s/g,"").replace("R$","");
  if(s.includes(",")) s=s.replace(/\./g,"").replace(",",".");
  return Number(s)||0;
}
function relMoeda(v){
  return Number(v||0).toLocaleString("pt-BR",{style:"currency",currency:"BRL"});
}
function relFormatarData(d){
  if(!d) return "";
  if(typeof formatarData === "function") return formatarData(d);
  const p=String(d).split("-");
  return p.length===3 ? p[2]+"/"+p[1]+"/"+p[0] : d;
}
function relDataVenda(v){
  let d = v.dataVenda || v.data || v.Data || "";
  if(!d && v.criadoEm){
    let p=String(v.criadoEm).split(" ")[0].split("/");
    if(p.length===3) d=p[2]+"-"+p[1].padStart(2,"0")+"-"+p[0].padStart(2,"0");
  }
  if(typeof d === "number"){
    const date = new Date(Math.round((d - 25569) * 86400 * 1000));
    d = date.toISOString().slice(0,10);
  }
  if(d instanceof Date) d = d.toISOString().slice(0,10);
  d = String(d||"").trim();
  if(/^\d{2}\/\d{2}\/\d{4}$/.test(d)){
    const p=d.split("/");
    d=p[2]+"-"+p[1]+"-"+p[0];
  }
  return d;
}
function relStatus(v){
  return v.statusVenda || v.status || v.statusPedido || "";
}
function relPedido(v){
  return String(v.numeroPedido || v.pedido || v.numero || "").trim();
}
function relValor(v){
  return v.valorLiquidoEstimado || v.valorBrutoPedido || v.valorVenda || v.valor || v.precoVenda || "";
}
function relQtd(v){
  const q = relNum(v.quantidadeItens || v.quantidade || v.qtd || 1);
  return q > 0 ? q : 1;
}
function relVendasFiltradas(){
  const listaBase = Array.isArray(window.vendas) ? window.vendas : (typeof vendas !== "undefined" && Array.isArray(vendas) ? vendas : []);
  const inicio = document.getElementById("relDataInicio")?.value || "";
  const fim = document.getElementById("relDataFim")?.value || "";
  const sku = document.getElementById("relSku")?.value || "";
  const status = document.getElementById("relStatus")?.value || "";
  const pedido = (document.getElementById("relPedido")?.value || "").toLowerCase();
  const ordem = document.getElementById("filtroOrdenacaoVendas")?.value || "recentes";

  const filtrada = listaBase.filter(v=>{
    const d = relDataVenda(v);
    if(inicio && d && d < inicio) return false;
    if(fim && d && d > fim) return false;
    if(inicio && !d) return false;
    if(fim && !d) return false;
    if(sku && String(v.sku||"") !== sku) return false;
    if(status && relStatus(v) !== status) return false;
    if(pedido && !relPedido(v).toLowerCase().includes(pedido)) return false;
    return true;
  });

  filtrada.sort((a,b)=>{
    const da = new Date((relDataVenda(a)||"1900-01-01")+"T12:00:00").getTime();
    const db = new Date((relDataVenda(b)||"1900-01-01")+"T12:00:00").getTime();
    return ordem === "antigas" ? da - db : db - da;
  });

  return filtrada;
}

window.obterVendasRelatorioAvancado = relVendasFiltradas;

window.renderizarRelatorioAvancado = function(){
  const tbody = document.getElementById("relAvTabela");
  if(!tbody) return;

  const lista = relVendasFiltradas();
  const totalValor = lista.reduce((s,v)=>s + relNum(relValor(v)), 0);

  const set = (id,val)=>{const e=document.getElementById(id); if(e) e.textContent=val;};
  set("relAvTotal", lista.length);
  set("relAvFaturado", lista.filter(v=>relStatus(v)==="Faturado").length);
  set("relAvEntregue", lista.filter(v=>relStatus(v)==="Entregue").length);
  set("relAvCancelado", lista.filter(v=>relStatus(v)==="Pedido cancelado").length);
  set("relAvValor", relMoeda(totalValor));

  tbody.innerHTML = "";
  if(!lista.length){
    tbody.innerHTML = '<tr><td colspan="8" class="empty">Nenhuma venda encontrada para os filtros selecionados.</td></tr>';
    return;
  }

  lista.forEach(v=>{
    const bruto = v.valorBrutoPedido || v.valorVenda || v.valor || "";
    const liquido = v.valorLiquidoEstimado || "";
    tbody.innerHTML += `<tr>
      <td>${relFormatarData(relDataVenda(v))}</td>
      <td class="sku-title">${relEsc(v.sku || "")}</td>
      <td>${relEsc(v.produto || v.sku || "")}</td>
      <td><span class="badge">${relEsc(relPedido(v))}</span></td>
      <td>${relEsc(relStatus(v))}</td>
      <td><strong>${relQtd(v)}</strong></td>
      <td>${bruto ? relEsc(bruto) : "-"}</td>
      <td>${liquido ? relEsc(liquido) : "-"}</td>
    </tr>`;
  });
};

window.limparFiltrosRelatorio = function(){
  ["relDataInicio","relDataFim","relPedido"].forEach(id=>{const e=document.getElementById(id); if(e) e.value="";});
  const sku=document.getElementById("relSku"); if(sku) sku.value="";
  const st=document.getElementById("relStatus"); if(st) st.value="";
  const ord=document.getElementById("filtroOrdenacaoVendas"); if(ord) ord.value="recentes";
  renderizarRelatorioAvancado();
};

})();
</script>


<script>
