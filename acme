<script>
(function(){
let modoGraficoCrescimento = "semana";

function acmeDataVendaCrescimento(v){
  if(v.dataVenda) return v.dataVenda;
  if(v.data) return v.data;
  if(typeof dataVendaInicial === "function") return dataVendaInicial(v);
  if(v.criadoEm){
    let partes = String(v.criadoEm).split(" ")[0].split("/");
    if(partes.length === 3) return partes[2]+"-"+partes[1].padStart(2,"0")+"-"+partes[0].padStart(2,"0");
  }
  return "";
}

function inicioSemanaISO(dataStr){
  const d = new Date(dataStr + "T12:00:00");
  if(isNaN(d.getTime())) return "";
  const dia = d.getDay() || 7;
  d.setDate(d.getDate() - dia + 1);
  return d.toISOString().slice(0,10);
}

function chavePeriodoVenda(v, modo){
  const data = acmeDataVendaCrescimento(v);
  if(!data) return "";
  if(modo === "mes") return String(data).slice(0,7);
  return inicioSemanaISO(data);
}

function rotuloPeriodo(chave, modo){
  if(!chave) return "";
  if(modo === "mes"){
    const p = chave.split("-");
    return p.length === 2 ? p[1] + "/" + p[0] : chave;
  }
  const d = new Date(chave + "T12:00:00");
  const fim = new Date(d);
  fim.setDate(fim.getDate() + 6);
  const iniBR = String(d.getDate()).padStart(2,"0") + "/" + String(d.getMonth()+1).padStart(2,"0");
  const fimBR = String(fim.getDate()).padStart(2,"0") + "/" + String(fim.getMonth()+1).padStart(2,"0");
  return iniBR + " a " + fimBR;
}

function dadosCrescimento(modo){
  if(typeof vendas === "undefined") return [];
  const grupos = {};
  (vendas || []).forEach(v=>{
    const chave = chavePeriodoVenda(v, modo);
    if(!chave) return;
    grupos[chave] = (grupos[chave] || 0) + 1;
  });

  const chaves = Object.keys(grupos).sort();
  return chaves.map((chave, i)=>{
    const atual = grupos[chave] || 0;
    const anterior = i > 0 ? (grupos[chaves[i-1]] || 0) : 0;
    let crescimento = 0;
    if(anterior > 0) crescimento = ((atual - anterior) / anterior) * 100;
    else if(atual > 0) crescimento = 100;
    return {chave, label:rotuloPeriodo(chave, modo), atual, anterior, crescimento};
  });
}

function desenharGraficoCrescimento(){
  const canvas = document.getElementById("graficoCrescimentoPercentual");
  if(!canvas) return;

  const dados = dadosCrescimento(modoGraficoCrescimento);
  const ctx = canvas.getContext("2d");
  const w = canvas.clientWidth || 900;
  const h = canvas.clientHeight || 360;
  canvas.width = w;
  canvas.height = h;
  ctx.clearRect(0,0,w,h);

  const elAtual = document.getElementById("cresPeriodoAtual");
  const elAnterior = document.getElementById("cresPeriodoAnterior");
  const elPct = document.getElementById("cresPercentualPeriodo");
  const elModo = document.getElementById("cresModo");

  if(elModo) elModo.textContent = modoGraficoCrescimento === "mes" ? "Mês" : "Semana";

  if(!dados.length){
    if(elAtual) elAtual.textContent = "0";
    if(elAnterior) elAnterior.textContent = "0";
    if(elPct) elPct.textContent = "0%";
    ctx.fillStyle = "#5681b5";
    ctx.font = "16px Arial";
    ctx.fillText("Nenhuma venda com data para calcular crescimento.", 20, 40);
    return;
  }

  const ultimo = dados[dados.length - 1];
  if(elAtual) elAtual.textContent = ultimo.atual;
  if(elAnterior) elAnterior.textContent = ultimo.anterior;
  if(elPct) elPct.textContent = (ultimo.crescimento >= 0 ? "+" : "") + ultimo.crescimento.toFixed(1).replace(".", ",") + "%";

  const margemEsq = 60, margemDir = 20, margemTopo = 35, margemBaixo = 80;
  const areaW = w - margemEsq - margemDir;
  const areaH = h - margemTopo - margemBaixo;
  const valores = dados.map(d=>d.crescimento);
  const maxAbs = Math.max(10, ...valores.map(v=>Math.abs(v)));
  const zeroY = margemTopo + areaH/2;
  const gap = 12;
  const bw = Math.max(24, (areaW / dados.length) - gap);

  ctx.strokeStyle = "#cfe4ff";
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(margemEsq, margemTopo);
  ctx.lineTo(margemEsq, margemTopo + areaH);
  ctx.lineTo(w - margemDir, margemTopo + areaH);
  ctx.stroke();

  ctx.strokeStyle = "#94a3b8";
  ctx.beginPath();
  ctx.moveTo(margemEsq, zeroY);
  ctx.lineTo(w - margemDir, zeroY);
  ctx.stroke();

  ctx.fillStyle = "#004fae";
  ctx.font = "bold 14px Arial";
  ctx.fillText("Crescimento percentual " + (modoGraficoCrescimento === "mes" ? "por mês" : "por semana"), margemEsq, 20);

  dados.forEach((d, i)=>{
    const x = margemEsq + i * (bw + gap) + gap;
    const altura = Math.abs(d.crescimento) / maxAbs * (areaH/2 - 12);
    const y = d.crescimento >= 0 ? zeroY - altura : zeroY;
    ctx.fillStyle = d.crescimento >= 0 ? "#10b981" : "#ef4444";
    ctx.fillRect(x, y, bw, altura || 2);

    ctx.fillStyle = "#102a43";
    ctx.font = "12px Arial";
    ctx.textAlign = "center";
    const txt = (d.crescimento >= 0 ? "+" : "") + d.crescimento.toFixed(1).replace(".", ",") + "%";
    ctx.fillText(txt, x + bw/2, d.crescimento >= 0 ? y - 6 : y + altura + 14);

    ctx.save();
    ctx.translate(x + bw/2, margemTopo + areaH + 42);
    ctx.rotate(-0.45);
    ctx.fillText(d.label, 0, 0);
    ctx.restore();
  });

  ctx.textAlign = "left";
}

window.mudarGraficoCrescimento = function(modo){
  modoGraficoCrescimento = modo;
