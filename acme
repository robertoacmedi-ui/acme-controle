<script>
(function(){
function pegarValorItemVenda(){
  const el = document.getElementById("valorItemVenda");
  return el ? String(el.value || "").trim() : "";
}

function limparValorItemVenda(){
  const el = document.getElementById("valorItemVenda");
  if(el) el.value = "";
}

// Intercepta salvar venda para incluir valor do item/produto no pedido salvo
const salvarVendaOriginalValorItem = window.salvarVenda;
window.salvarVenda = function(){
  const valorItem = pegarValorItemVenda();

  const antes = Array.isArray(window.vendas) ? window.vendas.length : (typeof vendas !== "undefined" && Array.isArray(vendas) ? vendas.length : 0);

  if(typeof salvarVendaOriginalValorItem === "function"){
    salvarVendaOriginalValorItem();
  }

  setTimeout(function(){
    try{
      const lista = Array.isArray(window.vendas) ? window.vendas : vendas;
      if(!Array.isArray(lista) || !valorItem) return;

      // Aplica ao pedido recém-criado, caso ele ainda não tenha valor
      if(lista.length > antes){
        if(!lista[0].valorVenda && !lista[0].valorItemProduto){
          lista[0].valorVenda = valorItem;
          lista[0].valorItemProduto = valorItem;
          if(typeof salvarLocal === "function") salvarLocal();
          if(typeof atualizarTudo === "function") atualizarTudo();
        }
      }
    }catch(e){}
  }, 150);
};

// Intercepta limpar para limpar também o campo valor
const limparVendaOriginalValorItem = window.limparVenda;
window.limparVenda = function(){
  if(typeof limparVendaOriginalValorItem === "function") limparVendaOriginalValorItem();
  limparValorItemVenda();
};
})();
</script>


