function acmeStatusImp(v){
  const s=String(v||"").toLowerCase();
  if(s.includes("cancel")) return "Pedido cancelado";
  if(s.includes("entreg")) return "Entregue";
  if(s.includes("fatur")) return "Faturado";
  if(s.includes("aguard") || s.includes("pag")) return "Aguardando pagamento";
  return v || "Aguardando pagamento";
}
function acmeNumeroImp(v){
  if(v === null || v === undefined || v === "") return 0;
  let s=String(v).trim().replace(/\s/g,"").replace("R$","");
  if(s.includes(",")) s=s.replace(/\./g,"").replace(",",".");
  return Number(s)||0;
}

window.importarPlanilhaVendas = async function(ev){
  const arq = ev.target.files && ev.target.files[0];
  if(!arq) return;

  let imp=0, dup=0, err=0;

  try{
    if(typeof XLSX==="undefined"){
      alert("Biblioteca de importação ainda não carregou. Atualize a página e tente novamente.");
      return;
    }

    const buffer = await arq.arrayBuffer();
    const wb = XLSX.read(buffer,{type:"array",cellDates:true});
    const sh = wb.Sheets[wb.SheetNames[0]];
    const rows = XLSX.utils.sheet_to_json(sh,{defval:""});

    if(typeof vendas === "undefined") window.vendas = [];
    if(typeof produtos === "undefined") window.produtos = [];

    rows.forEach(row=>{
      const dataPedido = acmeCampoExato(row, ["Data do Pedido"]);
      const numeroPedido = String(acmeCampoExato(row, ["Numero do pedido", "Número do pedido"])).trim();
      const quantidadePacotes = acmeNumeroImp(acmeCampoExato(row, ["Quantidade de pacotes"]));
      const sku = String(acmeCampoExato(row, ["Codigo SKU seller", "Código SKU seller", "SKU seller"])).trim();
      const quantidadeItens = acmeNumeroImp(acmeCampoExato(row, ["Quantidade de itens"]));
      const valorBrutoPedido = acmeCampoExato(row, ["Valor bruto do pedido"]);
      const valorTotalItensPedido = acmeCampoExato(row, ["Valor total dos itens do pedido"]);
      const statusPedido = acmeCampoExato(row, ["Status do pedido"]);
      const valorLiquidoEstimado = acmeCampoExato(row, ["Valor Liquido estimado a receber", "Valor Líquido estimado a receber"]);

      if(!sku || !numeroPedido){
        err++;
        return;
      }

      // Pedido duplicado continua bloqueado, mas a separação principal é por SKU seller.
      if((vendas||[]).some(v=>String(v.numeroPedido||v.pedido||"").trim().toLowerCase() === numeroPedido.toLowerCase())){
        dup++;
        return;
      }

      const produto = sku; // A planilha não possui coluna produto; usamos SKU como referência principal.

      const venda = {
        id: Date.now() + Math.floor(Math.random()*1000000),
        sku: sku,
        produto: produto,
        numeroPedido: numeroPedido,
        dataVenda: acmeDataImp(dataPedido),
        dataVendaFixada:false,
        statusVenda: acmeStatusImp(statusPedido),
        criadoEm: new Date().toLocaleString("pt-BR"),

        // Campos da planilha
        quantidadePacotes: quantidadePacotes,
        quantidadeItens: quantidadeItens || 1,
        valorVenda: valorBrutoPedido,
        valorBrutoPedido: valorBrutoPedido,
        valorTotalItensPedido: valorTotalItensPedido,
        valorLiquidoEstimado: valorLiquidoEstimado,

        observacaoImportacao: "Importado por Codigo SKU seller"
      };

      vendas.unshift(venda);

      if(sku && !(produtos||[]).some(p=>String(p.sku||"").toLowerCase() === sku.toLowerCase())){
        produtos.push({sku:sku, nome:produto});
      }

      imp++;
    });

    if(typeof salvarLocal==="function") salvarLocal();
    if(typeof atualizarTudo==="function") atualizarTudo();
    if(typeof renderizarRelatorioAvancado==="function") renderizarRelatorioAvancado();
    if(typeof renderizarRankingProdutosVendidos==="function") renderizarRankingProdutosVendidos();

    const a=document.getElementById("impImportados"); if(a) a.textContent=imp;
    const b=document.getElementById("impDuplicados"); if(b) b.textContent=dup;
    const c=document.getElementById("impErros"); if(c) c.textContent=err;
    const d=document.getElementById("impUltima"); if(d) d.textContent=new Date().toLocaleTimeString("pt-BR");

    alert(`Importação concluída.\nPedidos incluídos no sistema: ${imp}\nDuplicados ignorados: ${dup}\nErros sem SKU/pedido: ${err}`);
  }catch(e){
    console.error(e);
    alert("Erro ao importar planilha. Verifique se as colunas estão corretas.");
  }finally{
    ev.target.value = "";
  }
};

